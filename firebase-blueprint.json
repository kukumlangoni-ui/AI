{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user plan, credit balance, and usage statistics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "plan": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "creditBalance": { "type": "number" },
        "totalTokens": { "type": "number" },
        "totalCredits": { "type": "number" },
        "premiumStatus": { "type": "boolean" },
        "mentorStatus": { "type": "string", "enum": ["none", "pending", "active"] },
        "accountStatus": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "email", "plan", "creditBalance"]
    },
    "UsageLog": {
      "title": "Usage Log",
      "description": "Records details of each AI interaction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "prompt": { "type": "string" },
        "response": { "type": "string" },
        "model": { "type": "string" },
        "inputTokens": { "type": "number" },
        "outputTokens": { "type": "number" },
        "totalTokens": { "type": "number" },
        "creditsDeducted": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "prompt", "response", "model", "totalTokens", "creditsDeducted", "timestamp"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Records user payments.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["topup", "subscription", "mentor"] },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "timestamp"]
    },
    "MentorRequest": {
      "title": "Mentor Request",
      "description": "Tracks mentor requests.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "completed"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "timestamp"]
    },
    "Settings": {
      "title": "Platform Settings",
      "description": "Global platform settings.",
      "type": "object",
      "properties": {
        "defaultModel": { "type": "string" },
        "creditFormula": { "type": "number" },
        "lowCreditThreshold": { "type": "number" },
        "freeStarterCredits": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles." },
    "/usage_logs/{logId}": { "schema": "UsageLog", "description": "AI usage logs." },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payment records." },
    "/mentor_requests/{requestId}": { "schema": "MentorRequest", "description": "Mentor requests." },
    "/settings/global": { "schema": "Settings", "description": "Global settings." }
  }
}
